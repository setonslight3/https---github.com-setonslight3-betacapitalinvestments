{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/BetterCapitalInvestment run build && node copy-build.js && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "devCommand": null,
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "FORCE_BUILD": "true"
  }
}
